*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }

html { scroll-behavior: smooth; text-size-adjust: none; }

body { min-height: 100dvh; font-family: var(--font-body); font-size: var(--text-base); line-height: 1.6; background: var(--color-bg); color: var(--color-text); }

img, svg { display: block; max-width: 100%; height: auto; }

a, button { transition: 180ms cubic-bezier(0.16, 1, 0.3, 1); }

a { color: inherit; text-decoration: none; }

button { font: inherit; border: none; background: none; cursor: pointer; }

:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; border-radius: var(--radius-sm); }

.skip-link { position: absolute; left: -9999px; top: auto; }

.skip-link:focus { left: var(--space-4); top: var(--space-4); background: var(--color-surface); padding: var(--space-3) var(--space-4); z-index: 100; border-radius: var(--radius-md); }

.container { max-width: var(--content-default); margin: 0px auto; padding: 0 var(--space-4); }

.header { position: sticky; top: 0px; z-index: 50; background: color-mix(in srgb, var(--color-bg) 88%, transparent); backdrop-filter: blur(12px); border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent); }

.header-inner { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) 0; gap: var(--space-4); }

.brand { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); font-weight: 700; letter-spacing: 0.02em; }

.brand-mark { width: 40px; height: 40px; color: var(--color-primary); }

.nav { display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; }

.nav a { font-size: var(--text-sm); color: var(--color-text-muted); }

.nav a:hover { color: var(--color-text); }

.theme-toggle { width: 44px; height: 44px; border-radius: var(--radius-full); display: grid; place-items: center; background: var(--color-surface); border: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent); }

.hero { padding: clamp(var(--space-12),12vw,var(--space-20)) 0 var(--space-12); }

.hero-grid { display: grid; gap: var(--space-8); align-items: end; }

.eyebrow { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-primary); font-weight: 700; margin-bottom: var(--space-4); }

h1, h2 { font-family: var(--font-display); line-height: 1.05; text-wrap: balance; }

h1 { font-size: var(--text-2xl); max-width: 12ch; margin-bottom: var(--space-4); }

h2 { font-size: var(--text-xl); margin-bottom: var(--space-3); }

p { max-width: 68ch; color: var(--color-text-muted); }

.hero p { font-size: var(--text-base); max-width: 58ch; }

.hero-actions { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-6); }

.button { display: inline-flex; align-items: center; justify-content: center; min-height: 44px; padding: 0 var(--space-5); border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 700; border: 1px solid transparent; }

.button-primary { background: var(--color-primary); color: white; }

.button-primary:hover { background: var(--color-primary-hover); }

.button-secondary { background: var(--color-surface); border-color: color-mix(in srgb, var(--color-text) 10%, transparent); }

.hero-card { background: linear-gradient(180deg,var(--color-surface),var(--color-surface-2)); padding: var(--space-6); border-radius: var(--radius-xl); box-shadow: var(--shadow-md); border: 1px solid color-mix(in srgb, var(--color-text) 8%, transparent); }

.stat { display: grid; grid-template-columns: auto 1fr; gap: var(--space-3); padding: var(--space-4) 0; border-top: 1px solid color-mix(in srgb, var(--color-text) 8%, transparent); }

.stat:first-of-type { border-top: none; padding-top: 0px; }

.stat strong { font-size: var(--text-lg); color: var(--color-text); }

section { padding: var(--space-12) 0; }

.section-head { display: grid; gap: var(--space-3); margin-bottom: var(--space-6); }

.cards { display: grid; gap: var(--space-4); }

.card { background: var(--color-surface); border: 1px solid color-mix(in srgb, var(--color-text) 8%, transparent); border-radius: var(--radius-xl); padding: var(--space-5); box-shadow: var(--shadow-sm); }

.card h3 { font-size: var(--text-lg); line-height: 1.2; margin-bottom: var(--space-2); }

.card p { font-size: var(--text-sm); }

.kicker { display: inline-block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); margin-bottom: var(--space-2); }

.timeline { display: grid; gap: var(--space-4); }

.step { display: grid; grid-template-columns: auto 1fr; gap: var(--space-4); align-items: start; }

.step-num { width: 2.25rem; height: 2.25rem; border-radius: 50%; display: grid; place-items: center; background: var(--color-primary-highlight); color: var(--color-primary); font-weight: 700; font-size: var(--text-sm); }

.donation-grid { display: grid; gap: var(--space-3); }

.donation-item { display: flex; justify-content: space-between; gap: var(--space-4); padding: var(--space-4); border-radius: var(--radius-lg); background: var(--color-surface); }

.donation-item span:last-child { color: var(--color-text-muted); text-align: right; }

.cta { background: var(--color-primary-highlight); border-radius: var(--radius-xl); padding: var(--space-8); border: 1px solid color-mix(in srgb, var(--color-primary) 18%, transparent); }

footer { padding: var(--space-8) 0 var(--space-12); color: var(--color-text-faint); font-size: var(--text-sm); }

@media (min-width: 800px) {
  .hero-grid { grid-template-columns: 1.35fr 0.9fr; }
  .cards { grid-template-columns: repeat(3, 1fr); }
  .timeline { grid-template-columns: repeat(2, 1fr); }
  .donation-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  * { transition: none !important; }
}
